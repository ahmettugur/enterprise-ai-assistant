{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:fresh": "ng cache clean && ng serve",
    "start:nocache": "ng serve --no-cache",
    "build": "ng build",
    "build:nocache": "ng build --no-cache",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "cache:clean": "ng cache clean",
    "cache:off": "ng cache disable",
    "cache:on": "ng cache enable"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@amcharts/amcharts5": "^5.14.4",
    "@amcharts/amcharts5-geodata": "^5.1.5",
    "@angular/animations": "^21.0.5",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@microsoft/signalr": "^10.0.0",
    "@primeng/themes": "^21.0.2",
    "apexcharts": "^5.3.6",
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^3.1.0",
    "d3": "^7.9.0",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "ng-apexcharts": "^2.0.4",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.0",
    "@types/d3": "^7.4.3",
    "typescript": "~5.9.2"
  }
}
